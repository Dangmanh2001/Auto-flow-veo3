<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Ví dụ POST Form</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        max-width: 600px;
        margin: 50px auto;
        padding: 20px;
      }
      .form-group {
        margin-bottom: 15px;
      }
      label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
      }
      input[type="file"] {
        padding: 5px;
      }
      input[type="submit"] {
        padding: 10px 20px;
        background-color: #4caf50;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 16px;
      }
      input[type="submit"]:hover {
        background-color: #45a049;
      }
      .preview {
        margin-top: 20px;
      }
      .preview img {
        max-width: 150px;
        margin: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <h1>Gửi Nhiều File Ảnh</h1>

    <!-- Form gửi file -->
    <form action="/api" method="POST" enctype="multipart/form-data">
      <!-- Input để chọn nhiều file ảnh -->
      <div class="form-group">
        <label for="images">Chọn ảnh (có thể chọn nhiều):</label>
        <input
          type="file"
          id="images"
          name="images"
          accept="image/*"
          multiple
          required
        />
      </div>

      <!-- Nút gửi -->
      <div class="form-group">
        <input type="submit" value="Gửi" />
      </div>
    </form>

    <!-- Hiển thị preview ảnh đã chọn -->
    <div class="preview" id="preview"></div>

    <script>
      // Preview ảnh khi chọn
      document
        .getElementById("images")
        .addEventListener("change", function (e) {
          const preview = document.getElementById("preview");
          preview.innerHTML = ""; // Clear preview cũ

          const files = this.files;

          for (let i = 0; i < files.length; i++) {
            const file = files[i];

            // Kiểm tra xem có phải file ảnh không
            if (file.type.startsWith("image/")) {
              const reader = new FileReader();

              reader.onload = function (e) {
                const img = document.createElement("img");
                img.src = e.target.result;
                preview.appendChild(img);
              };

              reader.readAsDataURL(file);
            }
          }

          // Hiển thị số lượng file
          console.log(`Đã chọn ${files.length} file`);
        });
    </script>
  </body>
</html>
